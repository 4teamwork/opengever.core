      <line class="axis" x1="0" y1="20"  x2="1000" y2="20"/>
      <text x="994" y="16" text-anchor="end">100 %</text>
      <line class="axis" x1="0" y1="65"  x2="1000" y2="65"/>
      <text x="994" y="61" text-anchor="end">75 %</text>
