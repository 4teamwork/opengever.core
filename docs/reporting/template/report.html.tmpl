<script>
// ── theme toggle ────────────────────────────────────────────────
const root = document.documentElement;
document.getElementById('themeToggle').addEventListener('click', () => {
  root.dataset.theme = root.dataset.theme === 'light' ? 'dark' : 'light';
});

// ── scroll reveal ───────────────────────────────────────────────
const io = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
}), { threshold: 0.12 });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// ── smooth section collapse/expand ────────────────────────────────
const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
const SECTION_EASE = 'cubic-bezier(0.19, 1, 0.22, 1)';
document.querySelectorAll('details.section').forEach(det => {
  const summary = det.querySelector(':scope > summary');
  const body = det.querySelector(':scope > .section-body');
  if (!summary || !body || reduceMotion) return;
  let anim = null;
  summary.addEventListener('click', e => {
    e.preventDefault();
    if (det.open) collapse(); else expand();
  });
  function expand() {
    anim?.cancel();
    det.open = true;
    const target = body.scrollHeight;
    anim = body.animate(
      { height: ['0px', target + 'px'] },
      { duration: 260, easing: SECTION_EASE }
    );
    anim.onfinish = () => { body.style.height = ''; };
  }
  function collapse() {
    anim?.cancel();
    const start = body.scrollHeight;
    anim = body.animate(
      { height: [start + 'px', '0px'] },
      { duration: 220, easing: SECTION_EASE }
    );
    anim.onfinish = () => { det.open = false; body.style.height = ''; };
  }
});

// ── count-up ────────────────────────────────────────────────────
const fmt = v => {
  const r = Math.round(v * 10) / 10;
  return Number.isInteger(r) ? String(r) : r.toFixed(1);
};
document.querySelectorAll('.countup').forEach(el => {
  const target = +el.dataset.target, t0 = performance.now(), dur = 1000;
  const tick = t => {
    const p = Math.min((t - t0) / dur, 1), e = 1 - Math.pow(1 - p, 4);
    el.textContent = fmt(target * e);
    if (p < 1) requestAnimationFrame(tick);
  };
  if (matchMedia('(prefers-reduced-motion: reduce)').matches) el.textContent = fmt(target);
  else requestAnimationFrame(tick);
});

// ── negative-value styling (budget variance etc.) ────────────────
document.querySelectorAll('[data-neg-if-negative]').forEach(el => {
  if (parseFloat(el.textContent) < 0) el.classList.add('neg');
});

// ── ink-block tooltip ────────────────────────────────────────────
const tip = document.getElementById('tip');
const tipL = tip.querySelector('.tt-l'), tipV = tip.querySelector('.tt-v');
const TIP_DELAY = 550;
let tipOn = false, tipTimer = null;

function moveTip(e) {
  const pad = 12, r = tip.getBoundingClientRect();
  let x = e.clientX + pad, y = e.clientY - r.height - pad;
  if (x + r.width > innerWidth - 8) x = e.clientX - r.width - pad;
  if (y < 8) y = e.clientY + pad;
  tip.style.left = x + 'px';
  tip.style.top  = y + 'px';
}
document.addEventListener('mouseover', e => {
  const t = e.target.closest?.('[data-tip]');
  if (!t) return;
  const [l, v] = t.dataset.tip.split('|');
  tipL.textContent = l; tipV.textContent = v || '';
  tipV.style.display = v ? '' : 'none';
  tipOn = true; moveTip(e);
  clearTimeout(tipTimer);
  tipTimer = setTimeout(() => { if (tipOn) tip.classList.add('show'); }, TIP_DELAY);
});
document.addEventListener('mouseout', e => {
  if (e.target.closest?.('[data-tip]')) {
    tipOn = false; clearTimeout(tipTimer); tip.classList.remove('show');
  }
});
document.addEventListener('mousemove', e => { if (tipOn) moveTip(e); });
</script>
</body>
</html>
