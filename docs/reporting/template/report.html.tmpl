<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{meta.project_name}} — Projektbericht</title>
<!--
  ══════════════════════════════════════════════════════════════════════
  TEMPLATE CONVENTIONS (this file is filled by an LLM, not a JS engine —
  read docs/reporting/CONTRACT.md §3 for the exact data shape):

    {{path.to.field}}          scalar token — verbatim substitution.
                                Every token here corresponds to a real
                                field/path in report-data.json.

    <!-- REPEAT xyz -->  ...  <!-- /REPEAT xyz -->
                                Wrap ONE template row/element. Repeat it
                                once per item in the named array, using
                                the loop-var prefix shown inside the
                                block (area., story., risk., cut., ...).
                                Delete the markers in the rendered output,
                                keep only the repeated rows.

    <!-- IF cond -->  ...  <!-- /IF -->
    <!-- IF NOT cond -->  ...  <!-- /IF -->
                                Conditional block. Keep the enclosed
                                markup only if the condition is
                                true/false; drop the markers themselves.

    <!-- COMPUTE: description -->
                                Not a literal data field but a small
                                rendering computation the filling agent
                                must perform from the named contract
                                fields (e.g. mapping a date range onto an
                                SVG viewBox). Replace the comment with
                                the computed markup/attribute.

  Delete ALL markers (REPEAT/IF/COMPUTE comments) in the final rendered
  report.html — only plain markup with real values should remain.
  ══════════════════════════════════════════════════════════════════════
-->
<style>
/* ══════════════════════════════════════════════════════════════════
   Swiss International Typographic Style — ink on paper.
   Tokens/type/ledger/chart system reused wholesale from
   /home/mca/Downloads/mockup-swiss.html. Content = project report.
   ══════════════════════════════════════════════════════════════════ */
:root {
  --accent: #266afe;             /* Fabasoft-Blau -- Marken-Akzent (CI/CD-Farbwelt) */
  --ease:   cubic-bezier(0.19, 1, 0.22, 1);
  --sans: "Helvetica Neue", Helvetica, Arial, sans-serif;
  --mono: ui-monospace, "SF Mono", Menlo, monospace;

  /* spacing scale */
  --s1: 4px; --s2: 8px; --s3: 12px; --s4: 16px; --s5: 24px; --s6: 40px; --s7: 72px;
}

:root[data-theme="light"] {
  --paper:    #f2f1ed;
  --ink:      #333332;
  --ink-2:    #666664;
  --ink-3:    #999896;
  --hairline: #cccbc8;
  --rule:     #333332;
  --fill:     #e5ddc3;
  --pos:      #333332;
  --neg:      #b3261e;
  --tl-gruen:   #397365;
  --tl-gelb:    #8a6a1f;
  --tl-gelbrot: #a6531f;
  --tl-rot:     #b3261e;
  --tl-grau:    #807f7d;
  --seg-sep:    #b2b2af;
}
:root[data-theme="dark"] {
  --paper:    #1c1b19;
  --ink:      #f2f1ed;
  --ink-2:    #cccbc8;
  --ink-3:    #999896;
  --hairline: #3d3b38;
  --rule:     #f2f1ed;
  --fill:     #2a2824;
  --pos:      #f2f1ed;
  --neg:      #ff6f61;
  --tl-gruen:   #559384;
  --tl-gelb:    #fff266;
  --tl-gelbrot: #ddb64d;
  --tl-rot:     #ff6f61;
  --tl-grau:    #999896;
  --seg-sep:    #595957;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--sans);
  background: var(--paper);
  color: var(--ink);
  line-height: 1.45;
  font-size: 15px;
  transition: background .4s, color .4s;
}
.mono { font-family: var(--mono); font-variant-numeric: tabular-nums; }
.num  { font-variant-numeric: tabular-nums; letter-spacing: -0.01em; }

/* faint paper grain */
body::after {
  content: ""; position: fixed; inset: 0; pointer-events: none; opacity: 0.03; z-index: 50;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
}

.page { max-width: 1060px; margin: 0 auto; padding: 0 32px 96px; }

/* ── Masthead ─────────────────────────────────────────────────── */
.masthead {
  display: flex; justify-content: space-between; align-items: baseline;
  padding: 26px 0 14px; flex-wrap: wrap; gap: var(--s3);
}
.masthead .title { font-size: 1.05rem; font-weight: 700; letter-spacing: 0.02em; }
.masthead .folio { font-family: var(--mono); font-size: 0.7rem; color: var(--ink-2); display: flex; gap: 20px; align-items: center; flex-wrap: wrap; }
.thick-rule { border: 0; border-top: 3px solid var(--rule); }
.hairline-rule { border: 0; border-top: 1px solid var(--hairline); }
.masthead-note { padding: var(--s3) 0 var(--s5); }

.ampel-dot { font-size: 0.75rem; margin-right: 4px; }
.dot-gruen    { color: var(--tl-gruen); }
.dot-gelb     { color: var(--tl-gelb); }
.dot-gelb-rot { color: var(--tl-gelbrot); }
.dot-rot      { color: var(--tl-rot); }
.dot-grau     { color: var(--tl-grau); }

.theme-btn {
  font-family: var(--mono); font-size: 0.65rem; letter-spacing: .1em; text-transform: uppercase;
  background: none; border: 1px solid var(--ink); color: var(--ink);
  padding: 4px 12px; cursor: pointer; transition: background .2s, color .2s;
}
.theme-btn:hover { background: var(--ink); color: var(--paper); }

/* ── Type system ──────────────────────────────────────────────── */
.kicker {
  font-family: var(--mono); font-size: 0.68rem; font-weight: 500;
  letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-2);
}
.kicker .en { color: var(--ink-3); text-transform: none; letter-spacing: 0.06em; margin-left: 10px; font-style: italic; }
.section-no { color: var(--accent); font-weight: 700; margin-right: 10px; }

.caption { font-size: 0.72rem; color: var(--ink-2); }
.footnote { font-size: 0.78rem; color: var(--ink-2); max-width: 62ch; }
.footnote b { color: var(--ink); font-weight: 700; }

/* ── Sections: separated by rules, not boxes; collapsible via <details> ── */
.section { padding: var(--s6) 0; }
.section + .section { border-top: 1px solid var(--hairline); }
.section > summary { list-style: none; cursor: pointer; user-select: none; }
.section > summary::-webkit-details-marker { display: none; }
.section > summary::marker { content: ""; }
.section > summary.kicker { display: flex; align-items: center; margin-bottom: var(--s5); }
.section > summary.kicker .toggle-ind {
  margin-left: auto; font-family: var(--mono); font-size: 0.85rem; font-weight: 700;
  color: var(--ink-3); transition: transform .25s var(--ease), color .2s;
}
.section > summary.kicker:hover .toggle-ind { color: var(--accent); }
.section[open] > summary.kicker .toggle-ind { transform: rotate(45deg); }
.section:not([open]) { padding-bottom: var(--s5); }
.section:not([open]) > summary.kicker { margin-bottom: 0; }

/* subtle open/close animation, driven by JS (Web Animations API) on .section-body;
   pure-CSS fallback (no-JS): native <details> toggling still works, just instant */
.section-body { overflow: hidden; }
@media (prefers-reduced-motion: reduce) { .section-body { overflow: visible; } }

/* reveal — crisp, fast, typesetting feel */
.reveal { opacity: 0; transform: translateY(14px); transition: opacity .5s var(--ease), transform .5s var(--ease); }
.reveal.in { opacity: 1; transform: none; }

/* ── Summary prose + traffic light ────────────────────────────── */
.summary-grid { display: flex; gap: var(--s7); align-items: flex-start; }
.summary-prose { font-size: 0.95rem; flex: 1; }
.summary-prose ul, .dash-list { list-style: none; }
.summary-prose li, .dash-list li { position: relative; padding: 5px 0 5px 18px; border-bottom: 1px solid var(--hairline); }
.summary-prose li:last-child, .dash-list li:last-child { border-bottom: 0; }
.summary-prose li::before, .dash-list li::before { content: "\2013"; position: absolute; left: 0; color: var(--accent); font-weight: 700; }
.summary-prose strong { font-weight: 700; }
.dash-list { font-size: 0.85rem; }
.ampel-tl { display: flex; flex-direction: column; gap: 10px; align-items: flex-start; flex-shrink: 0; padding-top: 2px; }
.ampel-tl .lamp-item { display: flex; align-items: center; gap: 10px; }
.ampel-tl .lamp { width: 26px; height: 26px; border-radius: 50%; border: 1.5px solid var(--ink-3); flex-shrink: 0; transition: background .3s, border-color .3s; }
.ampel-tl .lamp-label { font-family: var(--mono); font-size: 0.62rem; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-3); }
.ampel-tl.state-gruen .lamp-item-gruen .lamp,
.ampel-tl.state-gelb .lamp-item-gelb .lamp,
.ampel-tl.state-gelb-rot .lamp-item-gelb .lamp,
.ampel-tl.state-gelb-rot .lamp-item-rot .lamp,
.ampel-tl.state-rot .lamp-item-rot .lamp { border-color: transparent; }
.ampel-tl.state-gruen .lamp-item-gruen .lamp { background: var(--tl-gruen); }
.ampel-tl.state-gelb .lamp-item-gelb .lamp { background: var(--tl-gelb); }
.ampel-tl.state-gelb-rot .lamp-item-gelb .lamp { background: var(--tl-gelb); }
.ampel-tl.state-gelb-rot .lamp-item-rot .lamp { background: var(--tl-rot); }
.ampel-tl.state-rot .lamp-item-rot .lamp { background: var(--tl-rot); }
.ampel-tl.state-gruen .lamp-item-gruen .lamp-label,
.ampel-tl.state-gelb .lamp-item-gelb .lamp-label,
.ampel-tl.state-gelb-rot .lamp-item-gelb .lamp-label,
.ampel-tl.state-gelb-rot .lamp-item-rot .lamp-label,
.ampel-tl.state-rot .lamp-item-rot .lamp-label { color: var(--ink); font-weight: 700; }
@media (max-width: 700px) { .summary-grid { flex-direction: column; } .ampel-tl { flex-direction: row; padding-top: var(--s4); } }

/* ── KPI columns with vertical hairlines ──────────────────────── */
.kpis { display: grid; grid-template-columns: repeat(4, 1fr); }
@media (max-width: 820px) { .kpis { grid-template-columns: repeat(2, 1fr); row-gap: var(--s5); } }
.kpi { padding: 0 var(--s5); border-left: 1px solid var(--hairline); }
.kpi:first-child { padding-left: 0; border-left: 0; }
.kpi .lbl { font-family: var(--mono); font-size: 0.62rem; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-2); margin-bottom: var(--s2); }
.kpi .val { font-size: 2.1rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
.kpi .val.neg { color: var(--neg); }
.kpi .sub { font-size: 0.72rem; color: var(--ink-2); margin-top: var(--s2); }
.kpi .bar { height: 3px; background: var(--fill); margin-top: var(--s3); position: relative; }
.kpi .bar i { position: absolute; inset: 0; right: auto; background: var(--accent); width: 0; transition: width .9s var(--ease) .2s; }
.in .kpi .bar i { width: var(--w); }

/* ── allocation — weight bar with progress fill + ledger table ── */
.alloc-bar { display: flex; height: 40px; border: 1px solid var(--ink); margin-bottom: var(--s4); }
.alloc-bar i { border-right: 2px solid var(--seg-sep); transition: background .9s var(--ease); position: relative; overflow: hidden; }
.alloc-bar i:last-child { border-right: 0; }
.alloc-bar i:hover { opacity: 0.85; }
.alloc-bar .seg-label {
  position: absolute; top: 3px; left: 3px;
  font-family: var(--mono); font-size: 0.58rem; font-weight: 700; letter-spacing: .03em;
  color: var(--paper); background: var(--ink); padding: 1px 4px; line-height: 1.4;
}
table.ledger { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
table.ledger th {
  font-family: var(--mono); font-size: 0.62rem; letter-spacing: .14em; text-transform: uppercase;
  color: var(--ink-2); font-weight: 500; text-align: left; padding: 8px 14px 8px 0;
  border-bottom: 2px solid var(--ink); white-space: nowrap;
}
table.ledger th.r, table.ledger td.r { text-align: right; }
table.ledger td { padding: 13px 14px 13px 0; border-bottom: 1px solid var(--hairline); }
table.ledger tfoot td { border-bottom: 0; border-top: 2px solid var(--ink); font-weight: 700; }
table.ledger tr:last-child td { border-bottom: 0; }
table.ledger tr:hover td { background: var(--fill); }
table.ledger .name { font-weight: 500; }
table.ledger .idx { font-family: var(--mono); font-size: 0.68rem; color: var(--ink-3); padding-right: 12px; }
.check { color: var(--ink); font-weight: 700; }
.flag  { color: var(--accent); font-weight: 700; }
.nowrap { white-space: nowrap; }

/* full-width table caption — not the width-capped .footnote */
.table-note { font-size: 0.72rem; color: var(--ink-2); margin-top: var(--s3); padding-top: var(--s3); border-top: 1px solid var(--hairline); }
.table-note b { color: var(--ink); font-weight: 700; }
td .verdict, .verdict { font-family: var(--mono); font-size: 0.66rem; letter-spacing: .08em; text-transform: uppercase; }
.verdict-gruen    { color: var(--tl-gruen); }
.verdict-gelb     { color: var(--tl-gelb); }
.verdict-gelb-rot { color: var(--tl-gelbrot); }
.verdict-rot      { color: var(--tl-rot); font-weight: 700; }
.verdict-grau     { color: var(--tl-grau); }

.divergence { display: block; font-size: 0.7rem; color: var(--ink-2); margin-top: 2px; }

/* inline meter used inside table cells (story/area progress) */
.mini-bar { width: 60px; height: 4px; background: var(--fill); display: inline-block; vertical-align: middle; margin-right: 6px; position: relative; }
.mini-bar i { position: absolute; inset: 0; right: auto; background: var(--ink); }

/* progress cell: bar on its own line, value below, both left-aligned */
td.progress-cell { text-align: left; }
td.progress-cell .mini-bar { display: block; margin: 0 0 5px; }
td.progress-cell .nowrap { display: block; }

.spec-badge {
  font-family: var(--mono); font-size: 0.62rem; letter-spacing: .06em; text-transform: uppercase;
  border: 1px solid var(--ink-3); padding: 1px 6px; color: var(--ink-2); text-decoration: none;
}
.spec-badge:hover { border-color: var(--ink); color: var(--ink); }

/* ── Budget bars (ink, data-ink chart) ─────────────────────────── */
.bar-chart-wrap { margin-bottom: var(--s5); }
.chart-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--s4); flex-wrap: wrap; gap: var(--s2); }
svg text { font-family: var(--mono); fill: var(--ink-3); font-size: 9.5px; letter-spacing: .04em; }
.axis { stroke: var(--hairline); stroke-width: 1; }
.axis.zero { stroke: var(--ink); }
.bar-el { fill: var(--ink); }
.bar-el:hover { opacity: 0.75; }
.chart-labels { display: flex; justify-content: space-around; font-family: var(--mono); font-size: 0.64rem; color: var(--ink-3); margin-top: var(--s2); }

.budget-figures { display: flex; gap: var(--s6); flex-wrap: wrap; margin-top: var(--s5); }
.budget-figures .fig .lbl { font-family: var(--mono); font-size: 0.62rem; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-2); margin-bottom: 4px; }
.budget-figures .fig .val { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.02em; }
.budget-figures .fig .val.neg { color: var(--neg); }

/* ── CI section ───────────────────────────────────────────────── */
.ci-headline { display: flex; align-items: baseline; gap: var(--s5); flex-wrap: wrap; }
.ci-headline .stat-value { font-size: 3rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
.ci-headline .stat-value .unit { font-size: 0.9rem; font-weight: 500; color: var(--ink-2); letter-spacing: 0; }
.ci-headline .stat-value.degraded { font-size: 1.6rem; color: var(--ink-2); }
.ci-link { font-family: var(--mono); font-size: 0.72rem; }
.ci-link a { color: var(--ink); }

/* ── Scope cuts / open decisions ─────────────────────────────────*/
.decisions { margin-top: var(--s5); }
.decisions ul { list-style: none; }
.decisions li { padding: 6px 0; border-bottom: 1px solid var(--hairline); font-size: 0.85rem; }
.decisions li:last-child { border-bottom: 0; }
.decisions a { color: var(--ink); text-decoration: underline; text-decoration-color: var(--ink-3); text-underline-offset: 2px; transition: color .2s; }
.decisions a:visited { color: var(--ink-2); }
.decisions a:hover { color: var(--accent); }

/* ── Trajectory / projection ─────────────────────────────────────*/
.proj-line { fill: none; stroke: var(--ink); stroke-width: 2; stroke-dasharray: 1400; stroke-dashoffset: 1400; }
.in .proj-line { animation: draw 1.4s var(--ease) forwards .1s; }
@keyframes draw { to { stroke-dashoffset: 0; } }
.ideal-line { fill: none; stroke: var(--ink-3); stroke-width: 1.5; stroke-dasharray: 6 5; }
.ideal-label { font-style: italic; }
.hist-pt { fill: var(--ink); stroke: var(--paper); stroke-width: 1.5; }
.marker-line { stroke: var(--ink-2); stroke-width: 1; stroke-dasharray: 3 4; }
.marker-line.stretch { stroke: var(--tl-gelbrot); }
.marker-label { font-size: 9px; }
.traj-legend { display: flex; gap: var(--s5); margin-top: var(--s3); font-family: var(--mono); font-size: 0.62rem; color: var(--ink-2); align-items: center; }
.traj-legend .swatch { display: inline-block; width: 18px; height: 0; border-top: 2px solid var(--ink); margin-right: 6px; vertical-align: middle; }
.traj-legend .swatch.ideal { border-top: 2px dashed var(--ink-3); }

/* ── Tooltip: solid ink block, sharp corners ──────────────────── */
#tip {
  position: fixed; z-index: 999; pointer-events: none;
  opacity: 0; transform: translateY(4px);
  transition: opacity .16s ease-out, transform .2s var(--ease);
  background: var(--ink); color: var(--paper);
  padding: 7px 10px; max-width: 280px;
}
#tip.show { opacity: 1; transform: none; }
#tip .tt-l { font-family: var(--mono); font-size: 0.56rem; letter-spacing: .14em; text-transform: uppercase; opacity: 0.6; margin-bottom: 2px; }
#tip .tt-v { font-family: var(--mono); font-size: 0.78rem; font-weight: 700; white-space: nowrap; }
[data-tip] { cursor: default; }

.countup { font-variant-numeric: tabular-nums; }

.colophon { font-family: var(--mono); font-size: 0.62rem; letter-spacing: .08em; color: var(--ink-3); display: flex; justify-content: space-between; padding-top: var(--s4); flex-wrap: wrap; gap: var(--s2); }

@media (prefers-reduced-motion: reduce) {
  *, .reveal, .proj-line { animation: none !important; transition: none !important; }
  .reveal { opacity: 1; transform: none; }
  .in .kpi .bar i { width: var(--w); }
}
</style>
</head>
<body>

<div id="tip"><div class="tt-l"></div><div class="tt-v"></div></div>

<div class="page">

  <!-- ══════════════════════════════════════════════════════════
       01 · MASTHEAD
       ══════════════════════════════════════════════════════════ -->
  <div class="masthead">
    <div class="title">{{meta.project_name}} — Projektbericht</div>
    <div class="folio">
      <!-- label: map token→Grün/Gelb/Rot/Grau/Gelb-Rot; class keeps token -->
      <span class="ampel-dot dot-{{ampel.display}}" data-tip="Ampel|{{ampel.display}}">●</span>
      <span>STAND {{meta.report_date_de}}</span>
      <span>BRANCH: {{meta.branch}}</span>
      <button class="theme-btn" id="themeToggle">Invert</button>
    </div>
  </div>
  <hr class="thick-rule">
  <div class="masthead-note caption">
    Branch wird nicht gemerged — Merges sind kein Fortschrittssignal.
    <span class="en" style="font-family:var(--mono); font-style:italic; margin-left:8px;">branch is not merged — merges are not a progress signal</span>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       01 · MANAGEMENT SUMMARY
       ══════════════════════════════════════════════════════════ -->
  <details class="section reveal" open>
    <summary class="kicker"><span class="section-no">01</span>Management Summary <span class="en">management summary</span><span class="toggle-ind">+</span></summary>
    <div class="section-body">
    <div class="summary-grid">
      <div class="summary-prose">{{summary_de}}</div>
      <!-- COMPUTE: ampel.display is one of gruen|gelb|gelb-rot|rot|grau. The outer div's
           state-{{ampel.display}} class drives which lamp(s) light via CSS (gelb-rot lights
           both gelb and rot; grau lights none). Do not compute anything else here, just
           substitute the token. -->
      <!-- label: map token→Grün/Gelb/Rot/Grau/Gelb-Rot in the data-tip value; class keeps token -->
      <div class="ampel-tl state-{{ampel.display}}" data-tip="Ampel|{{ampel.display}}">
        <div class="lamp-item lamp-item-gruen"><span class="lamp"></span><span class="lamp-label">gruen</span></div>
        <div class="lamp-item lamp-item-gelb"><span class="lamp"></span><span class="lamp-label">gelb</span></div>
        <div class="lamp-item lamp-item-rot"><span class="lamp"></span><span class="lamp-label">rot</span></div>
      </div>
    </div>
    </div>
  </details>

  <!-- ══════════════════════════════════════════════════════════
       02 · KPI-LEISTE
       ══════════════════════════════════════════════════════════ -->
  <details class="section reveal" open>
    <summary class="kicker"><span class="section-no">02</span>Kennzahlen <span class="en">kpi overview</span><span class="toggle-ind">+</span></summary>
    <div class="section-body">
    <div class="kpis">
      <div class="kpi">
        <div class="lbl">Gesamtfortschritt</div>
        <div class="val num"><span class="countup" data-target="{{kpis.gesamtfortschritt_pct}}">0</span> %</div>
        <div class="bar" data-tip="Gesamtfortschritt|{{kpis.gesamtfortschritt_pct}} %"><i style="--w:{{kpis.gesamtfortschritt_pct}}%"></i></div>
      </div>
      <div class="kpi">
        <div class="lbl">Budgetverbrauch</div>
        <div class="val num"><span class="countup" data-target="{{kpis.budgetverbrauch_pct}}">0</span> %</div>
